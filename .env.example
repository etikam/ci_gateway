# Copier vers `.env` sur la machine qui exécute Traefik (ne pas committer `.env`).
#
# E-mail accepté par Let's Encrypt (alertes d’expiration, etc.).
ACME_EMAIL=admin@example.com

# Serveur ACME Let's Encrypt :
# - Production (certificats reconnus par les navigateurs) :
ACME_CA_SERVER=https://acme-v02.api.letsencrypt.org/directory
#
# - Staging (pour tests sans plafond de rate limit ; certificats NON reconnus) :
# ACME_CA_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory
